# Copy to .kamal/secrets (gitignored) and fill in. Kamal reads it as a shell
# script. Only the registry credentials are needed for this static site.

# Docker registry (Docker Hub or ECR) — can reuse the portal's credentials.
KAMAL_REGISTRY_USERNAME=
KAMAL_REGISTRY_PASSWORD=

# Host (also export in your shell before running kamal):
# export SOCIAL_BANKERS_SERVER_IP=1.2.3.4
